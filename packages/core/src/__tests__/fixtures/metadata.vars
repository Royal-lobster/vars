
API_KEY  z.string().min(32)
  @description "Primary API key for external service"
  @expires     2026-09-01
  @owner       backend-team
  @dev     = sk_test_abcdefghijklmnopqrstuvwxyz123456
  @prod    = enc:v1:aes256gcm:dGVzdA==:Y2lwaGVy:dGFn

JWT_SECRET  z.string().min(64)
  @expires     2026-06-01
  @dev     = devjwtsecretdevjwtsecretdevjwtsecretdevjwtsecretdevjwtsecretdevjwtsecre

LEGACY_TOKEN  z.string().min(16)
  @deprecated "Use API_KEY instead"
  @dev     = legacy-token-value-here

QUOTED_VAR  z.string()
  @dev     = "value with spaces"
  @staging = 'single quoted'
  @prod    = simple

EMPTY_VAR  z.string()
  @dev     = ""
