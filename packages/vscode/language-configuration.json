{
	"comments": {
		"lineComment": "#"
	},
	"brackets": [["(", ")"], ["[", "]"]],
	"autoClosingPairs": [
		{ "open": "(", "close": ")" },
		{ "open": "[", "close": "]" },
		{ "open": "\"", "close": "\"" },
		{ "open": "'", "close": "'" }
	],
	"surroundingPairs": [
		{ "open": "(", "close": ")" },
		{ "open": "[", "close": "]" },
		{ "open": "\"", "close": "\"" },
		{ "open": "'", "close": "'" }
	],
	"folding": {
		"markers": {
			"start": "^\\s*#\\s*──",
			"end": "^\\s*$"
		}
	},
	"indentationRules": {
		"increaseIndentPattern": "^[A-Z_][A-Z0-9_]*\\s{2,}z\\.",
		"decreaseIndentPattern": "^[A-Z_][A-Z0-9_]*\\s{2,}z\\.|^\\s*$|^#|^@refine|^@extends"
	},
	"wordPattern": "[A-Za-z_][A-Za-z0-9_]*"
}
