{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "vars",
	"scopeName": "source.vars",
	"patterns": [
		{ "include": "#state-header" },
		{ "include": "#comment" },
		{ "include": "#env-declaration" },
		{ "include": "#param-declaration" },
		{ "include": "#use-declaration" },
		{ "include": "#check-block" },
		{ "include": "#group-block" },
		{ "include": "#variable-declaration" },
		{ "include": "#env-block-entry" },
		{ "include": "#metadata-block-entry" },
		{ "include": "#conditional" }
	],
	"repository": {
		"state-header": {
			"match": "^(#)\\s+(@vars-state)\\s+(locked|unlocked)\\s*$",
			"captures": {
				"1": { "name": "comment.line.number-sign.vars" },
				"2": { "name": "comment.line.state.vars" },
				"3": { "name": "comment.line.state.vars" }
			}
		},
		"comment": {
			"match": "^\\s*#.*$",
			"name": "comment.line.number-sign.vars"
		},
		"env-declaration": {
			"begin": "\\b(env)\\s*(\\()",
			"end": "\\)",
			"beginCaptures": {
				"1": { "name": "keyword.control.vars" },
				"2": { "name": "punctuation.brackets.round.vars" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.brackets.round.vars" }
			},
			"patterns": [
				{
					"match": "[a-z][a-zA-Z0-9_]*",
					"name": "variable.other.env.vars"
				},
				{
					"match": ",",
					"name": "punctuation.separator.comma.vars"
				}
			]
		},
		"param-declaration": {
			"match": "^(param)\\s+([a-z][a-zA-Z0-9_]*)\\s*(?::\\s*(enum)\\s*(\\()([^)]*)(\\)))?(?:\\s*(=)\\s*(.+))?$",
			"captures": {
				"1": { "name": "keyword.control.vars" },
				"2": { "name": "variable.other.env.vars" },
				"3": { "name": "keyword.control.vars" },
				"4": { "name": "punctuation.brackets.round.vars" },
				"5": {
					"patterns": [
						{
							"match": "[a-z][a-zA-Z0-9_]*",
							"name": "variable.other.env.vars"
						},
						{
							"match": ",",
							"name": "punctuation.separator.comma.vars"
						}
					]
				},
				"6": { "name": "punctuation.brackets.round.vars" },
				"7": { "name": "keyword.operator.assignment.vars" },
				"8": { "name": "variable.other.env.vars" }
			}
		},
		"use-declaration": {
			"begin": "^(use)\\s+",
			"end": "$",
			"beginCaptures": {
				"1": { "name": "keyword.control.vars" }
			},
			"patterns": [
				{
					"match": "\"([^\"]+)\"",
					"captures": {
						"0": { "name": "string.quoted.double.import.vars" }
					}
				},
				{
					"match": "\\{",
					"name": "punctuation.brackets.curly.vars"
				},
				{
					"match": "\\}",
					"name": "punctuation.brackets.curly.vars"
				},
				{
					"match": "\\b(pick|omit)\\b",
					"name": "keyword.other.filter.vars"
				},
				{
					"match": ":",
					"name": "punctuation.separator.colon.vars"
				},
				{
					"match": "\\[",
					"name": "punctuation.brackets.square.vars"
				},
				{
					"match": "\\]",
					"name": "punctuation.brackets.square.vars"
				},
				{
					"match": "[A-Z_][A-Z0-9_]*",
					"name": "entity.name.variable.vars"
				},
				{
					"match": ",",
					"name": "punctuation.separator.comma.vars"
				}
			]
		},
		"check-block": {
			"begin": "^(check)\\s+(\"[^\"]*\")\\s*(\\{)",
			"end": "\\}",
			"beginCaptures": {
				"1": { "name": "keyword.control.vars" },
				"2": { "name": "string.quoted.double.vars" },
				"3": { "name": "punctuation.brackets.curly.vars" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.brackets.curly.vars" }
			},
			"patterns": [
				{ "include": "#comment" },
				{ "include": "#conditional" },
				{ "include": "#comparison-operators" },
				{ "include": "#arrow-operator" },
				{ "include": "#variable-name" },
				{ "include": "#string-value" },
				{ "include": "#boolean-value" },
				{ "include": "#numeric-value" }
			]
		},
		"group-block": {
			"begin": "^(group)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\{)",
			"end": "\\}",
			"beginCaptures": {
				"1": { "name": "keyword.control.vars" },
				"2": { "name": "entity.name.type.group.vars" },
				"3": { "name": "punctuation.brackets.curly.vars" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.brackets.curly.vars" }
			},
			"patterns": [
				{ "include": "#comment" },
				{ "include": "#variable-declaration" },
				{ "include": "#env-block-entry" },
				{ "include": "#metadata-block-entry" },
				{ "include": "#conditional" }
			]
		},
		"variable-declaration": {
			"patterns": [
				{
					"comment": "Variable with env block: [public] NAME : schema { ... } [(metadata)]",
					"begin": "^\\s*(public\\s+)?([A-Z_][A-Z0-9_]*)\\s*(?::\\s*(z\\.[^{=(]+?))?\\s*(\\{)",
					"end": "\\}(\\s*\\(([^)]*)\\))?",
					"beginCaptures": {
						"1": { "name": "keyword.control.vars" },
						"2": { "name": "entity.name.variable.vars" },
						"3": {
							"patterns": [{ "include": "#zod-schema" }]
						},
						"4": { "name": "punctuation.brackets.curly.vars" }
					},
					"endCaptures": {
						"2": {
							"patterns": [{ "include": "#metadata-inline" }]
						}
					},
					"patterns": [
						{ "include": "#comment" },
						{ "include": "#env-block-entry" },
						{ "include": "#conditional" }
					]
				},
				{
					"comment": "Variable with inline value: [public] NAME : schema = value [(metadata)]",
					"match": "^\\s*(public\\s+)?([A-Z_][A-Z0-9_]*)\\s*(?::\\s*(z\\.[^=]+?))?\\s*(=)\\s*(enc:[^\\s(]+|\"\"\"[\\s\\S]*?\"\"\"|\"[^\"]*\"|true|false|[0-9][^\\s(]*)(?:\\s*(\\(([^)]*)\\)))?\\s*$",
					"captures": {
						"1": { "name": "keyword.control.vars" },
						"2": { "name": "entity.name.variable.vars" },
						"3": {
							"patterns": [{ "include": "#zod-schema" }]
						},
						"4": { "name": "keyword.operator.assignment.vars" },
						"5": {
							"patterns": [
								{ "include": "#encrypted-value" },
								{ "include": "#triple-string" },
								{ "include": "#string-value" },
								{ "include": "#boolean-value" },
								{ "include": "#numeric-value" }
							]
						},
						"6": {
							"patterns": [{ "include": "#metadata-inline" }]
						}
					}
				},
				{
					"comment": "Variable schema-only (no value, no block)",
					"match": "^\\s*(public\\s+)?([A-Z_][A-Z0-9_]*)\\s*:\\s*(z\\.[^={\\n]+?)\\s*$",
					"captures": {
						"1": { "name": "keyword.control.vars" },
						"2": { "name": "entity.name.variable.vars" },
						"3": {
							"patterns": [{ "include": "#zod-schema" }]
						}
					}
				}
			]
		},
		"env-block-entry": {
			"match": "^\\s+([a-z][a-zA-Z0-9_]*)\\s*(=)\\s*(enc:[^\\s]+|\"\"\"[\\s\\S]*?\"\"\"|\"[^\"]*\"|true|false|[0-9]\\S*)\\s*$",
			"captures": {
				"1": { "name": "variable.other.env.vars" },
				"2": { "name": "keyword.operator.assignment.vars" },
				"3": {
					"patterns": [
						{ "include": "#encrypted-value" },
						{ "include": "#triple-string" },
						{ "include": "#string-value" },
						{ "include": "#boolean-value" },
						{ "include": "#numeric-value" },
						{ "include": "#unquoted-value" }
					]
				}
			}
		},
		"metadata-block-entry": {
			"match": "^\\s+(description|owner|expires|deprecated|tags)\\s*(=)\\s*(.+)\\s*$",
			"captures": {
				"1": { "name": "entity.other.attribute-name.vars" },
				"2": { "name": "keyword.operator.assignment.vars" },
				"3": {
					"patterns": [
						{ "include": "#string-value" },
						{ "include": "#numeric-value" },
						{ "include": "#boolean-value" },
						{ "include": "#unquoted-value" }
					]
				}
			}
		},
		"metadata-inline": {
			"patterns": [
				{
					"match": "\\b(description|owner|expires|deprecated|tags)\\b",
					"name": "entity.other.attribute-name.vars"
				},
				{
					"match": "=",
					"name": "keyword.operator.assignment.vars"
				},
				{ "include": "#string-value" },
				{ "include": "#numeric-value" },
				{ "include": "#boolean-value" },
				{
					"match": ",",
					"name": "punctuation.separator.comma.vars"
				}
			]
		},
		"conditional": {
			"patterns": [
				{
					"match": "^\\s*(when)\\s+([a-z][a-zA-Z0-9_]*)\\s*(==|!=|>=|<=|>|<)\\s*(\\S+)\\s*(=>)\\s*(.*)$",
					"captures": {
						"1": { "name": "keyword.control.vars" },
						"2": { "name": "variable.other.env.vars" },
						"3": { "name": "keyword.operator.comparison.vars" },
						"4": {
							"patterns": [
								{ "include": "#string-value" },
								{ "include": "#boolean-value" },
								{ "include": "#numeric-value" },
								{ "include": "#unquoted-value" }
							]
						},
						"5": { "name": "keyword.operator.arrow.vars" },
						"6": {
							"patterns": [
								{ "include": "#encrypted-value" },
								{ "include": "#string-value" },
								{ "include": "#boolean-value" },
								{ "include": "#numeric-value" },
								{ "include": "#unquoted-value" }
							]
						}
					}
				},
				{
					"match": "^\\s*(else)\\s*(=>)\\s*(.*)$",
					"captures": {
						"1": { "name": "keyword.control.vars" },
						"2": { "name": "keyword.operator.arrow.vars" },
						"3": {
							"patterns": [
								{ "include": "#encrypted-value" },
								{ "include": "#string-value" },
								{ "include": "#boolean-value" },
								{ "include": "#numeric-value" },
								{ "include": "#unquoted-value" }
							]
						}
					}
				}
			]
		},
		"comparison-operators": {
			"match": "==|!=|>=|<=|>|<",
			"name": "keyword.operator.comparison.vars"
		},
		"arrow-operator": {
			"match": "=>",
			"name": "keyword.operator.arrow.vars"
		},
		"logical-operators": {
			"match": "\\b(and|or|not)\\b",
			"name": "keyword.operator.logical.vars"
		},
		"builtin-functions": {
			"match": "\\b(defined|matches|one_of|length|starts_with)\\b",
			"name": "support.function.vars"
		},
		"variable-name": {
			"match": "\\b[A-Z_][A-Z0-9_]*\\b",
			"name": "entity.name.variable.vars"
		},
		"zod-schema": {
			"patterns": [
				{
					"match": "\\bz\\b",
					"name": "support.type.schema.vars"
				},
				{
					"match": "\\.(string|number|boolean|date|bigint|enum|nativeEnum|coerce|literal|union|optional|nullable|array|object|tuple|record|any|unknown|never|void|undefined|null)\\b",
					"name": "support.type.schema.vars"
				},
				{
					"match": "\\.(min|max|email|url|uuid|regex|startsWith|endsWith|int|positive|negative|nonnegative|nonpositive|finite|safe|default|transform|refine|superRefine|pipe|brand|catch|describe|trim|toLowerCase|toUpperCase|length|nonempty|includes|datetime|ip|cuid|cuid2|ulid|nanoid|step|multipleOf|gte|lte|gt|lt)\\b",
					"name": "support.type.schema.vars"
				},
				{
					"match": "\"[^\"]*\"",
					"name": "string.quoted.double.vars"
				},
				{
					"match": "\\b\\d+\\b",
					"name": "constant.numeric.vars"
				},
				{
					"match": "[()]",
					"name": "punctuation.brackets.round.vars"
				},
				{
					"match": ",",
					"name": "punctuation.separator.comma.vars"
				},
				{
					"match": "\\.",
					"name": "punctuation.accessor.dot.vars"
				}
			]
		},
		"encrypted-value": {
			"match": "enc:v\\d+:[a-zA-Z0-9_-]+(?::[A-Za-z0-9+/=_-]+)*",
			"name": "string.encrypted.vars"
		},
		"triple-string": {
			"begin": "\"\"\"",
			"end": "\"\"\"",
			"name": "string.quoted.triple.vars"
		},
		"string-value": {
			"match": "\"[^\"]*\"",
			"name": "string.quoted.double.vars"
		},
		"boolean-value": {
			"match": "\\b(true|false)\\b",
			"name": "constant.language.boolean.vars"
		},
		"numeric-value": {
			"match": "\\b\\d+(\\.\\d+)?\\b",
			"name": "constant.numeric.vars"
		},
		"unquoted-value": {
			"match": "[^\\s#,)\\]]+",
			"name": "string.unquoted.value.vars"
		}
	}
}
