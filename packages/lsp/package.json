{
	"name": "@dotvars/lsp",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
			"require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
		}
	},
	"bin": {
		"vars-lsp": "./dist/index.cjs"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@dotvars/core": "workspace:*",
		"vscode-languageserver": "^9.0.0",
		"vscode-languageserver-textdocument": "^1.0.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"tsup": "^8.3.0",
		"vitest": "^3.0.0",
		"typescript": "^5.7.0"
	}
}
