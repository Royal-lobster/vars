# ── Basic v2 fixture ──────────────────────────────
env(dev, staging, prod)

DATABASE_URL : z.string().url() {
  dev     = "postgres://localhost:5432/myapp_dev"
  staging = "postgres://staging-host:5432/myapp_staging"
  prod    = "postgres://prod-host:5432/myapp_prod"
}

PORT : z.coerce.number().int().min(1024).max(65535) {
  dev  = 3000
  prod = 8080
}

LOG_LEVEL : z.enum(["debug", "info", "warn", "error"]) {
  dev  = "debug"
  prod = "info"
}

public DEBUG : z.coerce.boolean() {
  dev  = true
  prod = false
}

ANALYTICS_ID : z.string().optional() {
  prod = "UA-123456"
}
